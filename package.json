{
    "name": "win-watch-25",
    "version": "1.0.0",
    "description": "Windows UI Automation Monitor",
    "author": "Max Zakharzhevskiy",
    "license": "ISC",
    "keywords": [],
    "main": "index.js",
    "workspaces": [
        "electron",
        "napi-plugin"
    ],
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron-winstaller",
            "electron",
            "esbuild"
        ]
    },
    "devDependencies": {
        "@types/node": "^22.15.3",
        "tsx": "^4.19.2"
    },
    "scripts": {
        "tsc": "pnpm --filter ww-electron run tsc",
        "dev": "pnpm --filter ww-electron run dev",
        "dev:debug": "pnpm --filter ww-electron run dev:debug",

        "gen": "pnpm --filter ww-electron run gen:icons-temp",
        "deps:electron:update": "pnpm --filter ww-electron up -L -i",

        "build:all": "tsx scripts/build-plugins.ts --debug",
        "build:all:release": "tsx scripts/build-plugins.ts --release",
        
        "build:native": "tsx scripts/build-plugins.ts --debug --native-only",
        "build:napi": "tsx scripts/build-plugins.ts --debug --napi-only",

        "build:native:release": "tsx scripts/build-plugins.ts --release --native-only",
        "build:napi:release": "tsx scripts/build-plugins.ts --release --napi-only",

        "build:exe": "pnpm build:all:release && pnpm --filter ww-electron run build && pnpm --filter ww-electron exec electron-builder --win --x64"
    }
}
